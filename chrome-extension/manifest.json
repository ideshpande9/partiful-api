{
  "manifest_version": 3,
  "name": "Partiful Guest Export",
  "version": "1.0",
  "description": "Export Partiful event guests to CSV",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://api.partiful.com/*",
    "https://partiful.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://partiful.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}